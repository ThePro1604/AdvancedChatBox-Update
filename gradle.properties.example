# Copy this file to C:\Users\YourUsername\.gradle\gradle.properties
# or rename to gradle.properties (but don't commit it!)

# GitHub Packages credentials
gpr.user=ThePro1604
gpr.key=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE

# To create a GitHub Personal Access Token:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token" → "Generate new token (classic)"
# 3. Give it a name like "Gradle Packages"
# 4. Check the "read:packages" scope
# 5. Click "Generate token"
# 6. Copy the token and paste it as gpr.key value above

